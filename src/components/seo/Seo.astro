---
import { SITE } from '../../consts';
import { canonicalFromPath, defaultAlternates, type AlternateLink } from '../../utils/seo';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  type?: 'website' | 'article';
  alternates?: AlternateLink[];
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  ogImage = SITE.defaultOgImage,
  type = 'website',
  alternates,
  publishedTime,
  modifiedTime,
  noindex = false
} = Astro.props;

const canonical = canonicalFromPath(canonicalPath);
const ogImageUrl = new URL(ogImage, SITE.url).toString();
const alternateLinks = alternates ?? defaultAlternates(canonicalPath);
const ogLocale = canonicalPath.startsWith('/en') ? 'en_US' : 'vi_VN';
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.name} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={canonical} />

{
  alternateLinks.map((link) => (
    <link rel="alternate" hreflang={link.hrefLang} href={link.href} />
  ))
}

<meta property="og:type" content={type} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
