---
import { SITE, type Locale } from '../../consts';
import { t } from '../../utils/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const i18n = t(lang);
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-[var(--border-color)] py-10 text-sm text-[var(--text-muted)]" role="contentinfo">
  <div class="container-shell flex flex-col gap-8">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
      <div class="max-w-sm">
        <h3 class="text-base font-semibold text-[var(--text-primary)] mb-2">{SITE.name}</h3>
        <p class="text-[var(--text-secondary)] leading-relaxed">AI Engineer — {lang === 'vi' ? 'Chia sẻ kinh nghiệm thực chiến về AI Agents, MLOps và triển khai AI trong doanh nghiệp.' : 'Practical insights on AI Agents, MLOps, and shipping AI in enterprise.'}</p>
      </div>
      <div class="flex gap-10">
        <nav class="flex flex-col gap-2" aria-label="Footer navigation">
          <a href={`/${lang}/blog`} class="transition hover:text-[var(--text-primary)]">{i18n.nav.blog}</a>
          <a href={`/${lang}/projects`} class="transition hover:text-[var(--text-primary)]">{i18n.nav.projects}</a>
          <a href={`/${lang}/about`} class="transition hover:text-[var(--text-primary)]">{i18n.nav.about}</a>
        </nav>
        <nav class="flex flex-col gap-2" aria-label="Social links">
          <a href={SITE.github} target="_blank" rel="noreferrer" class="transition hover:text-[var(--text-primary)]">GitHub</a>
          <a href={SITE.linkedin} target="_blank" rel="noreferrer" class="transition hover:text-[var(--text-primary)]">LinkedIn</a>
          <a href={SITE.email} class="transition hover:text-[var(--text-primary)]">Email</a>
        </nav>
      </div>
    </div>
    <p class="text-xs text-[var(--text-muted)]">© {year} {SITE.name}</p>
  </div>
</footer>
