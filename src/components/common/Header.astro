---
import { SITE, type Locale } from '../../consts';
import { t } from '../../utils/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  lang: Locale;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const i18n = t(lang);
const homePath = `/${lang}`;

const navItems = [
  { href: homePath, label: i18n.nav.home, external: false },
  { href: `/${lang}/blog`, label: i18n.nav.blog, external: false },
  { href: `/${lang}/projects`, label: i18n.nav.projects, external: false },
  { href: `/${lang}/about`, label: i18n.nav.about, external: false },
  { href: `/${lang}/contact`, label: i18n.nav.contact, external: false },
  { href: SITE.portfolio, label: i18n.nav.portfolio, external: true },
];

const isActive = (href: string) => {
  if (href === homePath) {
    return pathname === homePath || pathname === `${homePath}/`;
  }
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-50 border-b border-[var(--border-color)] bg-[color-mix(in_srgb,var(--bg-primary)_88%,transparent)] backdrop-blur-md">
  <div class="container-shell flex items-center justify-between gap-4 h-16">
    <a href={`/${lang}`} class="text-xl font-bold tracking-tight text-[var(--text-primary)]">{SITE.name}</a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noreferrer' : undefined}
            class:list={[
              'text-sm font-medium px-3 py-1.5 rounded-md transition-colors',
              !item.external && isActive(item.href)
                ? 'text-[var(--brand)] bg-[var(--brand-subtle)]'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-surface)]'
            ]}
          >
            {item.label}{item.external ? ' ↗' : ''}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button
        id="search-trigger"
        type="button"
        class="inline-flex items-center gap-2 rounded-md border border-[var(--border-color)] px-3 py-1.5 text-sm text-[var(--text-muted)] transition hover:border-[var(--brand)] hover:text-[var(--brand)] cursor-pointer"
        aria-label={i18n.nav.search}
        onclick="window.__openSearch?.()"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <kbd class="hidden md:inline-flex items-center font-mono text-[10px] text-[var(--text-muted)] border border-[var(--border-color)] rounded px-1 py-0.5 leading-none">⌘K</kbd>
      </button>
      <LanguageSwitcher lang={lang} pathname={pathname} />
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-md text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-surface)] transition cursor-pointer"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav id="mobile-nav" class="hidden md:hidden border-t border-[var(--border-color)] py-3" aria-label="Mobile navigation">
    <div class="container-shell flex flex-col gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noreferrer' : undefined}
            class:list={[
              'text-sm font-medium px-3 py-2.5 rounded-md transition-colors',
              !item.external && isActive(item.href)
                ? 'text-[var(--brand)] bg-[var(--brand-subtle)]'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-surface)]'
            ]}
          >
            {item.label}{item.external ? ' ↗' : ''}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('hidden');
  });
</script>
