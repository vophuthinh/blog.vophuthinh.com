---
import type { Locale } from '../../consts';
import { t } from '../../utils/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const i18n = t(lang);
---

<!-- Search Modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label={i18n.pages.searchTitle}>
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Modal container -->
  <div class="relative flex items-start justify-center pt-[10vh] px-4 h-full">
    <div id="search-panel" class="w-full max-w-2xl bg-[var(--bg-surface)] border border-[var(--border-color)] rounded-lg shadow-lg overflow-hidden flex flex-col max-h-[70vh]">
      <!-- Header -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-[var(--border-color)]">
        <svg class="w-5 h-5 text-[var(--text-muted)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          id="search-input"
          type="search"
          placeholder={i18n.pages.searchPlaceholder}
          class="flex-1 bg-transparent text-[var(--text-primary)] text-base outline-none placeholder:text-[var(--text-muted)]"
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 rounded border border-[var(--border-color)] text-[var(--text-muted)] text-xs font-mono">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="overflow-y-auto flex-1 px-4 py-3">
        <div id="search-empty" class="flex flex-col items-center justify-center py-12 text-[var(--text-muted)]">
          <svg class="w-12 h-12 mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <p class="text-sm">{i18n.pages.searchDescription}</p>
        </div>
        <div id="search-loading" class="hidden flex items-center justify-center py-12">
          <div class="w-6 h-6 border-2 border-[var(--border-color)] border-t-[var(--brand)] rounded-full animate-spin"></div>
        </div>
        <div id="search-results-list" class="flex flex-col gap-1"></div>
        <div id="search-no-results" class="hidden flex flex-col items-center justify-center py-12 text-[var(--text-muted)]">
          <p class="text-sm" id="search-no-results-text"></p>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ searchLang: lang }}>
(() => {
  let pagefind = null;
  let debounceTimer = null;

  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const input = document.getElementById('search-input');
  const emptyState = document.getElementById('search-empty');
  const loadingState = document.getElementById('search-loading');
  const resultsList = document.getElementById('search-results-list');
  const noResults = document.getElementById('search-no-results');
  const noResultsText = document.getElementById('search-no-results-text');

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
      return pagefind;
    } catch {
      return null;
    }
  }

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      input.focus();
      input.value = '';
      showEmpty();
    });
    loadPagefind();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    resultsList.innerHTML = '';
    showEmpty();
  }

  function showEmpty() {
    emptyState.classList.remove('hidden');
    loadingState.classList.add('hidden');
    noResults.classList.add('hidden');
    resultsList.innerHTML = '';
  }

  function showLoading() {
    emptyState.classList.add('hidden');
    loadingState.classList.remove('hidden');
    noResults.classList.add('hidden');
    resultsList.innerHTML = '';
  }

  function showNoResults(term) {
    emptyState.classList.add('hidden');
    loadingState.classList.add('hidden');
    noResults.classList.remove('hidden');
    noResultsText.textContent = searchLang === 'vi'
      ? `Không tìm thấy kết quả cho "${term}"`
      : `No results for "${term}"`;
  }

  function showResults() {
    emptyState.classList.add('hidden');
    loadingState.classList.add('hidden');
    noResults.classList.add('hidden');
  }

  function renderResult(result) {
    const a = document.createElement('a');
    a.href = result.url;
    a.className = 'block rounded-lg px-3 py-3 transition-colors hover:bg-[var(--bg-card)] group';
    a.innerHTML = `
      <div class="font-medium text-[var(--text-primary)] group-hover:text-[var(--brand)] transition-colors text-sm">${result.meta?.title || result.url}</div>
      ${result.excerpt ? `<div class="text-xs text-[var(--text-muted)] mt-1 line-clamp-2">${result.excerpt}</div>` : ''}
    `;
    a.addEventListener('click', () => closeModal());
    return a;
  }

  async function performSearch(query) {
    if (!query || query.length < 2) {
      showEmpty();
      return;
    }

    const pf = await loadPagefind();
    if (!pf) return;

    showLoading();

    const search = await pf.search(query);
    if (!search.results.length) {
      showNoResults(query);
      return;
    }

    const results = await Promise.all(
      search.results.slice(0, 8).map(r => r.data())
    );

    resultsList.innerHTML = '';
    results.forEach(r => resultsList.appendChild(renderResult(r)));
    showResults();
  }

  // Event: input
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => performSearch(input.value.trim()), 200);
  });

  // Event: backdrop click
  backdrop.addEventListener('click', closeModal);

  // Event: escape + keyboard shortcut
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
      return;
    }
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal.classList.contains('hidden')) {
        openModal();
      } else {
        closeModal();
      }
    }
  });

  // Expose for header button
  window.__openSearch = openModal;
})();
</script>

<style>
  #search-modal {
    animation: fadeIn 0.15s ease-out;
  }

  #search-panel {
    animation: slideUp 0.2s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  #search-input::-webkit-search-cancel-button {
    display: none;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
