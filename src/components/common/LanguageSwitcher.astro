---
import type { Locale } from '../../consts';
import { switchLocalePath, t } from '../../utils/i18n';

interface Props {
  lang: Locale;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const nextLocale = lang === 'vi' ? 'en' : 'vi';
const targetPath = switchLocalePath(pathname, nextLocale);
const label = t(lang).nav.switchLang;
---

<a
  href={targetPath}
  class="rounded-md border border-[var(--border-color)] px-3 py-2 text-xs font-medium uppercase tracking-wider text-[var(--text-muted)] transition hover:border-[var(--brand)] hover:text-[var(--brand)] min-h-[36px] inline-flex items-center"
>
  {label}
</a>
