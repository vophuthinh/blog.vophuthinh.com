---
import type { ProjectEntry } from '../../utils/projects';
import type { Locale } from '../../consts';
import { buildProjectPath, getProjectSlug } from '../../utils/projects';
import TechStack from './TechStack.astro';
import { Image } from 'astro:assets';

interface Props {
  project: ProjectEntry;
  lang: Locale;
}

const { project, lang } = Astro.props;
const projectSlug = getProjectSlug(project);
---

<article class="group bg-[var(--bg-card)] border border-[var(--border-color)] rounded-lg overflow-hidden transition-colors hover:border-[var(--brand-light)] flex flex-col h-full">
  <div class="h-44 w-full bg-[var(--bg-surface)] overflow-hidden border-b border-[var(--border-color)]">
    {project.data.cover && (
      <Image
        src={project.data.cover}
        alt={project.data.title}
        widths={[400, 600]}
        sizes="(min-width: 768px) 50vw, 100vw"
        class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  <div class="p-5 flex flex-col flex-grow">
    <h2 class="text-xl font-semibold leading-snug tracking-[-0.01em] text-[var(--text-primary)] group-hover:text-[var(--brand)] transition-colors mb-2">{project.data.title}</h2>
    <p class="text-[var(--text-secondary)] mb-4 flex-grow">{project.data.description}</p>
    <div class="flex flex-wrap gap-1.5 mb-5">
      {project.data.techStack.map((tech) => (
        <span class="pill">{tech}</span>
      ))}
    </div>
    <div class="flex gap-2 border-t border-[var(--border-color)] pt-4">
      {project.data.demoUrl && (
        <a href={project.data.demoUrl} target="_blank" rel="noreferrer" class="text-sm flex items-center gap-1 px-3 py-1.5 bg-[var(--brand)] text-white rounded-md transition-colors font-medium hover:bg-[var(--brand-hover)]">
          Live Demo
        </a>
      )}
      <a href={buildProjectPath(lang, projectSlug)} class="text-sm flex items-center gap-1 px-3 py-1.5 border border-[var(--border-color)] text-[var(--text-primary)] rounded-md hover:border-[var(--brand-light)] hover:text-[var(--brand)] transition-colors font-medium">
        Details →
      </a>
      {project.data.githubUrl && (
        <a href={project.data.githubUrl} target="_blank" rel="noreferrer" class="text-sm flex items-center gap-1 px-3 py-1.5 border border-[var(--border-color)] text-[var(--text-primary)] rounded-md hover:border-[var(--brand-light)] hover:text-[var(--brand)] transition-colors font-medium">
          GitHub
        </a>
      )}
    </div>
  </div>
</article>
