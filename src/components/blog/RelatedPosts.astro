---
import type { BlogPost } from '../../utils/posts';
import type { Locale } from '../../consts';
import { buildPostPath, getPostSlug } from '../../utils/posts';

interface Props {
  posts: BlogPost[];
  lang: Locale;
  title: string;
}

const { posts, lang, title } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="mt-12 border-t border-[var(--border-color)] pt-8">
      <h2 class="mb-5 text-xl font-semibold tracking-tight">{title}</h2>
      <div class="grid gap-4 md:grid-cols-3">
        {
          posts.map((post) => (
            <a
              href={buildPostPath(lang, getPostSlug(post))}
              class="glass-card rounded-lg p-4 transition hover:border-[var(--brand-soft)]"
            >
              <p class="text-xs font-medium uppercase tracking-widest text-[var(--text-muted)]">{post.data.category}</p>
              <h3 class="mt-1.5 font-semibold text-[var(--text-primary)]">{post.data.title}</h3>
            </a>
          ))
        }
      </div>
    </section>
  )
}
