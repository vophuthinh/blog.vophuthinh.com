---
import type { Locale } from '../../consts';
import { buildTagPath } from '../../utils/posts';

interface Props {
  tags: string[];
  lang: Locale;
}

const { tags, lang } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <a href={buildTagPath(lang, tag)} class="pill hover:border-[var(--brand-light)] hover:text-[var(--brand)] transition-colors">#{tag}</a>
    ))
  }
</div>
