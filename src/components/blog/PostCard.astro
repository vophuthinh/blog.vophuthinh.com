---
import type { BlogPost } from '../../utils/posts';
import type { Locale } from '../../consts';
import { buildPostPath, getPostSlug, estimateReadingTime } from '../../utils/posts';
import { formatDate } from '../../utils/date';
import { t } from '../../utils/i18n';

interface Props {
  post: BlogPost;
  lang: Locale;
}

const { post, lang } = Astro.props;
const i18n = t(lang);
const postSlug = getPostSlug(post);
const readingTime = estimateReadingTime(post.body);
---

<a href={buildPostPath(lang, postSlug)} class="group bg-[var(--bg-card)] border border-[var(--border-color)] rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-[var(--brand-light)]/50 hover:shadow-[0_0_20px_rgba(236,24,57,0.12)] flex flex-col h-full cursor-pointer">
  <div class="h-48 w-full bg-[var(--bg-primary)] relative overflow-hidden border-b border-[var(--border-color)]">
    {post.data.cover && (
      <img
        src={post.data.cover}
        alt={post.data.title}
        class="w-full h-full object-cover opacity-75 group-hover:opacity-90 transition-opacity duration-300"
        width="600"
        height="300"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  <div class="p-6 flex flex-col flex-grow gap-2">
    <div class="flex items-center gap-2 text-sm text-[var(--text-muted)]">
      <time class="font-mono text-[var(--brand)]">{formatDate(post.data.pubDate, lang)}</time>
      <span class="text-[var(--border-color)]">·</span>
      <span>{readingTime} {i18n.common.minRead}</span>
    </div>
    <h2 class="text-xl font-semibold leading-[1.3] text-[var(--text-primary)] group-hover:text-[var(--brand)] transition-colors">{post.data.title}</h2>
    <p class="text-[var(--text-secondary)] text-sm flex-grow line-clamp-2">{post.data.description}</p>
    <div class="flex flex-wrap gap-1 mt-auto pt-3 border-t border-[var(--border-color)]">
      {post.data.tags.slice(0, 3).map((tag) => (
        <span class="font-mono text-[11px] bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-secondary)] px-2 py-0.5 rounded uppercase tracking-wider">{tag}</span>
      ))}
    </div>
  </div>
</a>
