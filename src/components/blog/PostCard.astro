---
import type { BlogPost } from '../../utils/posts';
import type { Locale } from '../../consts';
import { buildPostPath, getPostSlug, estimateReadingTime } from '../../utils/posts';
import { formatDate } from '../../utils/date';
import { t } from '../../utils/i18n';

interface Props {
  post: BlogPost;
  lang: Locale;
  featured?: boolean;
}

const { post, lang, featured = false } = Astro.props;
const i18n = t(lang);
const postSlug = getPostSlug(post);
const readingTime = estimateReadingTime(post.body);
---

<a
  href={buildPostPath(lang, postSlug)}
  class:list={[
    'group flex flex-col border border-[var(--border-color)] rounded-lg overflow-hidden transition-colors hover:border-[var(--brand-light)] bg-[var(--bg-card)]',
    featured && 'md:col-span-2 md:flex-row'
  ]}
>
  {post.data.cover && (
    <div class:list={[
      'bg-[var(--bg-primary)] overflow-hidden border-b border-[var(--border-color)]',
      featured ? 'h-48 md:h-auto md:w-2/5 md:border-b-0 md:border-r' : 'h-44'
    ]}>
      <img
        src={post.data.cover}
        alt={post.data.title}
        class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity"
        width="600"
        height="300"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}
  <div class:list={[
    'flex flex-col flex-grow gap-3 p-5',
    featured && 'md:p-7 md:justify-center'
  ]}>
    <div class="flex items-center gap-2 text-xs text-[var(--text-muted)]">
      <time class="font-mono text-[var(--brand)]">{formatDate(post.data.pubDate, lang)}</time>
      <span>·</span>
      <span>{readingTime} {i18n.common.minRead}</span>
    </div>
    <h2 class:list={[
      'font-semibold leading-snug text-[var(--text-primary)] group-hover:text-[var(--brand)] transition-colors',
      featured ? 'text-xl md:text-2xl' : 'text-lg'
    ]}>{post.data.title}</h2>
    <p class="text-sm text-[var(--text-secondary)] line-clamp-2">{post.data.description}</p>
    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-auto pt-3">
        {post.data.tags.slice(0, 3).map((tag) => (
          <span class="pill">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
