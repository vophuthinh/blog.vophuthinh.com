---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="vi"
  title="404 | Not Found"
  description="Page not found"
  canonicalPath="/404"
  noindex={true}
>
  <main id="main-content" class="container-shell py-16">
    <section class="py-20 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-[var(--brand)]">404</p>
      <h1 id="not-found-title" class="mt-3 text-4xl font-bold tracking-tight">Không tìm thấy trang</h1>
      <p id="not-found-desc" class="mx-auto mt-4 max-w-md text-[var(--text-secondary)]">Bạn có thể quay lại trang chủ để tiếp tục duyệt nội dung.</p>
      <a id="not-found-cta" href="/vi" class="mt-8 inline-block rounded bg-[var(--brand)] px-5 py-2.5 text-sm font-semibold text-white transition hover:brightness-105">
        Về trang chủ
      </a>
    </section>
  </main>

  <script is:inline>
    (() => {
      const isEn = window.location.pathname.startsWith('/en');
      if (isEn) {
        const title = document.getElementById('not-found-title');
        const desc = document.getElementById('not-found-desc');
        const cta = document.getElementById('not-found-cta');
        if (title) title.textContent = 'Page Not Found';
        if (desc) desc.textContent = "The page you're looking for doesn't exist. Head back to the homepage.";
        if (cta) { cta.textContent = 'Back to Home'; cta.href = '/en'; }
        document.documentElement.lang = 'en';
      }
    })();
  </script>
</BaseLayout>
