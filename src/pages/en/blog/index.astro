---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import { t } from '../../../utils/i18n';
import { getCategories, getPostsByLang } from '../../../utils/posts';

const lang = 'en' as const;
const i18n = t(lang);
const posts = await getPostsByLang(lang);
const categories = getCategories(posts);
---

<BaseLayout
  lang={lang}
  title={`${i18n.pages.blogTitle} | Võ Phú Thịnh`}
  description={i18n.pages.blogDescription}
  canonicalPath="/en/blog"
>
  <main id="main-content" class="container-shell py-16 flex flex-col gap-10">
    <!-- Header Section -->
    <section class="max-w-3xl flex flex-col gap-4">
      <h1 class="text-[48px] font-bold leading-[1.1] tracking-[-0.02em]">{i18n.pages.blogTitle}</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)]">{i18n.pages.blogDescription}</p>
    </section>

    <!-- Category Filter -->
    <section class="flex flex-wrap gap-2 border-b border-[var(--border-color)] pb-6">
      <button class="filter-btn active text-sm font-medium px-3 py-1.5 rounded-lg bg-[var(--brand)] text-white transition-all hover:opacity-90" data-category="">All</button>
      {categories.map((category) => (
        <button class="filter-btn text-sm font-medium px-3 py-1.5 rounded-lg bg-[var(--bg-card)] border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-[var(--brand-light)] hover:text-[var(--text-primary)] transition-all" data-category={category}>{category}</button>
      ))}
    </section>

    <!-- Blog Grid -->
    <section id="post-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map((post) => (
        <div data-category={post.data.category} data-tags={post.data.tags.join(',')} data-title={post.data.title.toLowerCase()}>
          <PostCard post={post} lang={lang} />
        </div>
      ))}
    </section>

    {posts.length === 0 && <p class="text-[var(--text-muted)]">{i18n.common.noPosts}</p>}
  </main>

  <script is:inline>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = Array.from(document.querySelectorAll('#post-grid > div'));
    let activeCategory = '';

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => {
          b.classList.remove('active', 'bg-[var(--brand)]', 'text-white');
          b.classList.add('bg-[var(--bg-card)]', 'border', 'border-[var(--border-color)]', 'text-[var(--text-secondary)]');
        });
        btn.classList.add('active', 'bg-[var(--brand)]', 'text-white');
        btn.classList.remove('bg-[var(--bg-card)]', 'border-[var(--border-color)]', 'text-[var(--text-secondary)]');
        activeCategory = btn.getAttribute('data-category') || '';
        cards.forEach((card) => {
          const category = card.getAttribute('data-category') || '';
          card.style.display = activeCategory && category !== activeCategory ? 'none' : '';
        });
      });
    });
  </script>
</BaseLayout>
