---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import ProjectCard from '../../components/project/ProjectCard.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { TOPICS, SITE } from '../../consts';
import { t } from '../../utils/i18n';
import { getFeaturedPosts, getLatestPosts, getPostsByLang, getSeries, buildSeriesPath, getPostsBySeries } from '../../utils/posts';
import { getFeaturedProjects, getProjectsByLang } from '../../utils/projects';

const lang = 'en' as const;
const i18n = t(lang);

const posts = await getPostsByLang(lang);
const projects = await getProjectsByLang(lang);
const latestPosts = getLatestPosts(posts, 4);
const featuredProjects = getFeaturedProjects(projects, 3);
const seriesList = getSeries(posts);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: ['vi', 'en'],
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE.url}/en/search/?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  url: SITE.portfolio,
  jobTitle: 'AI Engineer',
  worksFor: { '@type': 'Organization', name: 'HPT Vietnam Corporation' },
  sameAs: [SITE.github, SITE.linkedin]
};
---

<BaseLayout
  lang={lang}
  title="Võ Phú Thịnh | Technical Blog & Portfolio"
  description={i18n.home.heroDescription}
  canonicalPath="/en"
>
  <Fragment slot="head">
    <JsonLd schema={websiteSchema} />
    <JsonLd schema={personSchema} />
  </Fragment>

  <main id="main-content" class="flex flex-col">
    <!-- Hero Section -->
    <section class="border-b border-[var(--border-color)]">
      <div class="container-shell py-20 md:py-28 max-w-3xl">
        <p class="text-sm font-medium text-[var(--brand)] tracking-wide mb-4">AI Engineer @ HPT Vietnam</p>
        <h1 class="text-[clamp(2.2rem,5vw,3.25rem)] font-bold leading-[1.1] tracking-[-0.03em] mb-6">{i18n.home.heroTitle}</h1>
        <p class="text-lg leading-relaxed text-[var(--text-secondary)] max-w-2xl mb-8">{i18n.home.heroDescription}</p>
        <div class="flex flex-wrap gap-3">
          <a href="/en/blog" class="btn-brand inline-flex items-center gap-2 rounded-md bg-[var(--brand)] px-5 py-2.5 text-sm font-semibold text-white transition">
            {i18n.common.viewAllPosts} →
          </a>
          <a href="/en/about" class="inline-flex items-center gap-2 rounded-md border border-[var(--border-color)] px-5 py-2.5 text-sm font-medium text-[var(--text-secondary)] transition hover:border-[var(--brand-light)] hover:text-[var(--text-primary)]">
            {i18n.nav.about}
          </a>
        </div>
      </div>
    </section>

    <div class="container-shell py-16 flex flex-col gap-20">
      <!-- Latest Posts -->
      <section class="flex flex-col gap-8">
        <div class="flex justify-between items-end">
          <h2 class="text-2xl font-semibold tracking-[-0.02em]">{i18n.home.latestPosts}</h2>
          <a href="/en/blog" class="text-sm font-medium text-[var(--brand)] hover:text-[var(--brand-light)] transition">{i18n.common.viewAllPosts} →</a>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          {latestPosts.map((post, idx) => <PostCard post={post} lang={lang} featured={idx === 0} />)}
        </div>
      </section>

      <!-- Featured Projects -->
      {featuredProjects.length > 0 && (
        <section class="flex flex-col gap-8">
          <div class="flex justify-between items-end">
            <h2 class="text-2xl font-semibold tracking-[-0.02em]">{i18n.home.featuredProjects}</h2>
            <a href="/en/projects" class="text-sm font-medium text-[var(--brand)] hover:text-[var(--brand-light)] transition">{i18n.common.viewAllProjects} →</a>
          </div>
          <div class="grid gap-5 md:grid-cols-2">
            {featuredProjects.map((project) => <ProjectCard project={project} lang={lang} />)}
          </div>
        </section>
      )}

      <!-- Series -->
      {seriesList.length > 0 && (
        <section class="flex flex-col gap-8">
          <h2 class="text-2xl font-semibold tracking-[-0.02em]">Series</h2>
          <div class="flex flex-col gap-3">
            {seriesList.map((series) => {
              const count = getPostsBySeries(posts, series).length;
              return (
                <a href={buildSeriesPath(lang, series)} class="group flex items-center justify-between gap-4 py-3 px-4 rounded-lg border border-[var(--border-color)] transition hover:border-[var(--brand-light)] hover:bg-[var(--bg-surface)]">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="text-[var(--brand)] text-sm font-mono">{String(count).padStart(2, '0')}</span>
                    <h3 class="font-medium text-[var(--text-primary)] truncate group-hover:text-[var(--brand)] transition-colors">{series}</h3>
                  </div>
                  <span class="text-[var(--text-muted)] text-sm flex-shrink-0">→</span>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <!-- CTA -->
      <section class="py-12 border-t border-[var(--border-color)]">
        <div class="max-w-lg">
          <h2 class="text-2xl font-semibold tracking-[-0.02em] mb-3">{i18n.home.contactCtaTitle}</h2>
          <p class="text-[var(--text-secondary)] mb-6">{i18n.home.contactCtaDescription}</p>
          <a href="/en/contact" class="btn-brand inline-flex items-center gap-2 rounded-md bg-[var(--brand)] px-5 py-2.5 text-sm font-semibold text-white transition">
            {i18n.home.contactCtaButton} →
          </a>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
