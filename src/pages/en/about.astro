---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts';

const lang = 'en' as const;

const highlights = [
  'Shipped 3 AI products to production in the first year at HPT.',
  'Built an AI chatbot that handled 850+ questions at HPT D-DAY 2025.',
  'Won 2nd and 3rd prizes in HPT AI in Business competition (2025).',
  'Focused on practical enterprise delivery with AI Agents, MLOps, and AI Governance.',
];

const skills = [
  {
    category: 'AI & LLM Engineering',
    items: [
      'OpenAI API',
      'Google Gemini',
      'Claude',
      'Llama',
      'RAG',
      'Corrective RAG',
      'AI Agents',
      'Prompt Engineering',
      'Function Calling',
      'Guardrails',
      'Evaluation Frameworks',
      'Tool-use Pipelines',
    ],
  },
  {
    category: 'Frameworks & Orchestration',
    items: [
      'Python',
      'FastAPI',
      'Flask',
      'LangChain',
      'LangGraph',
      'n8n',
      'Apache Airflow',
      'Celery',
      'REST API',
      'WebSocket',
    ],
  },
  {
    category: 'Data & Machine Learning',
    items: [
      'SQL',
      'PostgreSQL',
      'MongoDB',
      'Pandas',
      'NumPy',
      'scikit-learn',
      'Feature Engineering',
      'Model Serving',
      'Power BI',
      'Data Storytelling',
    ],
  },
  {
    category: 'Vector DB & Search',
    items: [
      'Qdrant',
      'Pinecone',
      'Weaviate',
      'Chroma',
      'Elasticsearch',
      'Hybrid Search',
      'Semantic Retrieval',
      'Metadata Filtering',
    ],
  },
  {
    category: 'Cloud, DevOps & MLOps',
    items: [
      'Docker',
      'Kubernetes',
      'AWS',
      'Azure',
      'GCP',
      'GitHub Actions',
      'CI/CD',
      'Terraform',
      'Prometheus',
      'Grafana',
      'MLflow',
      'DVC',
    ],
  },
  {
    category: 'Web & Product Delivery',
    items: [
      'React',
      'Next.js',
      'Astro',
      'Node.js',
      'TypeScript',
      'Tailwind CSS',
      'System Design',
      'A/B Thinking',
      'Product Analytics',
      'UX for AI Products',
    ],
  },
];

const timeline = [
  {
    year: 'Oct 2025 — Present',
    title: 'AI Engineer · HPT Vietnam Corporation (AI Center of Excellence)',
    description:
      'Developed LLM-powered solutions for executive decision support, shipped AI chatbot handling 850+ questions/day, and won 2 enterprise AI awards.'
  },
  {
    year: 'Apr 2025 — Oct 2025',
    title: 'Software Solutions Engineer · HPT Vietnam Corporation',
    description:
      'Built 10+ automation workflows with n8n/Power Platform/UiPath, reducing manual reporting by ~60% and integrating AI for document processing.'
  },
];
---

<BaseLayout
  lang={lang}
  title="About | Võ Phú Thịnh"
  description="AI Engineer at HPT CoE specializing in AI Agents, MLOps, AI Governance, and production AI systems for enterprise use cases."
  canonicalPath="/en/about"
>
  <main id="main-content" class="container-shell py-16 flex flex-col gap-16">
    <section class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-7 flex flex-col gap-6">
        <p class="text-sm font-mono uppercase tracking-widest text-[var(--brand)]">About Me</p>
        <h1 class="font-bold leading-[1.1] tracking-[-0.02em]" style="font-size: clamp(2rem, 5vw, 3rem)">Võ Phú Thịnh</h1>
        <p class="text-lg leading-relaxed text-[var(--text-secondary)] max-w-2xl">
          I am an AI Engineer at HPT Vietnam Corporation (AI Center of Excellence), focused on building production-grade AI systems for real enterprise outcomes.
        </p>
        <p class="text-base leading-relaxed text-[var(--text-secondary)] max-w-2xl">
          My work spans AI Agents, MLOps, AI Governance, and workflow automation. I care about shipping fast, measuring impact clearly, and making AI reliable for business operations.
        </p>
        <div class="flex flex-wrap gap-4 pt-2">
          <a href={SITE.portfolio} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-[var(--brand)] px-5 py-2.5 text-sm font-medium text-white transition hover:brightness-105">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            View Full CV
          </a>
          <a href={SITE.github} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[var(--border-color)] px-5 py-2.5 text-sm font-medium text-[var(--text-primary)] transition hover:border-[var(--brand-light)] hover:text-[var(--brand)]">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href={SITE.linkedin} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[var(--border-color)] px-5 py-2.5 text-sm font-medium text-[var(--text-primary)] transition hover:border-[var(--brand-light)] hover:text-[var(--brand)]">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>

      <div class="md:col-span-5 bg-[var(--bg-card)] border border-[var(--border-color)] rounded-lg p-8">
        <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span class="text-[var(--brand)]">›_</span>
          <span>whoami</span>
        </h3>
        <div class="font-mono text-sm text-[var(--text-secondary)] space-y-2">
          <p><span class="text-[var(--brand)]">role:</span> AI Engineer</p>
          <p><span class="text-[var(--brand)]">company:</span> HPT Vietnam · AI CoE</p>
          <p><span class="text-[var(--brand)]">focus:</span> AI Agents, MLOps, AI Governance</p>
          <p><span class="text-[var(--brand)]">stack:</span> Python, FastAPI, LangChain, n8n</p>
          <p><span class="text-[var(--brand)]">location:</span> Ho Chi Minh City</p>
        </div>
      </div>
    </section>

    <section class="flex flex-col gap-8">
      <h2 class="text-2xl font-semibold leading-snug tracking-[-0.01em]">Highlights</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {highlights.map((item) => (
          <div class="bg-[var(--bg-card)] border border-[var(--border-color)] rounded-lg p-5 text-[var(--text-secondary)] leading-relaxed">
            {item}
          </div>
        ))}
      </div>
    </section>

    <section class="flex flex-col gap-8">
      <h2 class="text-2xl font-semibold leading-snug tracking-[-0.01em]">Tech Stack</h2>
      <p class="text-[var(--text-secondary)] leading-relaxed max-w-3xl">
        I focus on full-cycle AI delivery, from problem framing and system architecture to deployment, observability, and business impact tracking. Here is the technology stack I have used across real-world projects.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skills.map((group) => (
          <div class="bg-[var(--bg-card)] border border-[var(--border-color)] rounded-lg p-6">
            <h3 class="text-sm font-medium uppercase tracking-wider text-[var(--brand)] mb-4">{group.category}</h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="font-mono text-xs bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-secondary)] px-3 py-1.5 rounded-md">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="flex flex-col gap-8">
      <h2 class="text-2xl font-semibold leading-snug tracking-[-0.01em]">Journey</h2>
      <div class="flex flex-col gap-6">
        {timeline.map((item) => (
          <div class="flex gap-6 items-start group">
            <div class="flex-shrink-0 w-32 text-right">
              <span class="font-mono text-sm text-[var(--brand)]">{item.year}</span>
            </div>
            <div class="flex flex-col gap-1 border-l-2 border-[var(--border-color)] group-hover:border-[var(--brand-light)] pl-6 pb-6 transition-colors">
              <h3 class="text-lg font-semibold">{item.title}</h3>
              <p class="text-[var(--text-secondary)] text-base leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-[var(--bg-card)] border border-[var(--border-color)] rounded-lg p-10 text-center flex flex-col items-center gap-4">
      <h2 class="text-2xl font-semibold leading-snug tracking-[-0.01em]">Let’s Build AI That Ships</h2>
      <p class="text-[var(--text-secondary)] text-lg max-w-lg">
        Open to full-time, contract, freelance, and remote opportunities.
      </p>
      <a href="/en/contact" class="mt-2 inline-flex items-center gap-2 rounded-md bg-[var(--brand)] px-6 py-2.5 text-sm font-medium text-white transition hover:brightness-105">
        Get in Touch →
      </a>
    </section>
  </main>
</BaseLayout>
