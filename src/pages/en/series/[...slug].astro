---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import { t } from '../../../utils/i18n';
import { getPostsByLang, getSeries, getPostsBySeries } from '../../../utils/posts';
import { slugify } from '../../../utils/slug';

const lang = 'en' as const;
const i18n = t(lang);

export async function getStaticPaths() {
  const posts = await getPostsByLang('en');
  const seriesList = getSeries(posts);
  return seriesList.map((series) => ({
    params: { slug: slugify(series) },
    props: { series }
  }));
}

const { series } = Astro.props;
const posts = await getPostsByLang(lang);
const filtered = getPostsBySeries(posts, series);
const title = i18n.pages.seriesTitle.replace('{name}', series);
const description = i18n.pages.seriesDescription.replace('{name}', series);
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  canonicalPath={`/en/series/${slugify(series)}`}
  noindex={filtered.length < 2}
>
  <main id="main-content" class="container-shell py-16 flex flex-col gap-10">
    <section class="max-w-3xl flex flex-col gap-4">
      <nav class="flex gap-2 text-sm text-[var(--text-muted)]">
        <a href="/en/blog" class="hover:text-[var(--brand)] transition-colors">Blog</a> /
        <span>{i18n.common.series}</span> /
        <span class="text-[var(--text-primary)]">{series}</span>
      </nav>
      <h1 class="text-[48px] font-bold leading-[1.1] tracking-[-0.02em]">{series}</h1>
      <p class="text-lg text-[var(--text-secondary)]">
        {i18n.pages.postsCount.replace('{count}', String(filtered.length))}
      </p>
    </section>

    <section class="flex flex-col gap-4">
      {filtered.map((post, index) => (
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[var(--brand)] text-white flex items-center justify-center text-sm font-bold">{index + 1}</span>
          <div class="flex-1">
            <PostCard post={post} lang={lang} />
          </div>
        </div>
      ))}
    </section>
  </main>
</BaseLayout>
