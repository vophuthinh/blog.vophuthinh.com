---
import { render } from 'astro:content';
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import { buildAbsoluteUrl } from '../../../utils/seo';
import {
  getPostsByLang,
  getPostSlug,
  getPostTranslationKey,
  getRelatedPosts,
  getPostsBySeries,
  getPrevNextPosts
} from '../../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPostsByLang('vi');
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) }
  }));
}

const slug = Astro.params.slug;
if (!slug) {
  throw new Error('Missing post slug.');
}

const posts = await getPostsByLang('vi');
const post = posts.find((item) => getPostSlug(item) === slug);
if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const enPosts = await getPostsByLang('en');
const translationKey = getPostTranslationKey(post);
const translatedPost = enPosts.find(
  (item) => getPostTranslationKey(item) === translationKey
);

const canonicalPath = `/vi/blog/${getPostSlug(post)}`;
const alternates = [
  { hrefLang: 'vi', href: buildAbsoluteUrl(canonicalPath) },
  {
    hrefLang: 'en',
    href: buildAbsoluteUrl(`/en/blog/${translatedPost ? getPostSlug(translatedPost) : getPostSlug(post)}`)
  },
  { hrefLang: 'x-default', href: buildAbsoluteUrl(canonicalPath) }
];

const relatedPosts = getRelatedPosts(post, posts, 3);
const seriesPosts = post.data.series ? getPostsBySeries(posts, post.data.series) : [];
const { prev: prevPost, next: nextPost } = getPrevNextPosts(post, posts);
const { Content } = await render(post);
---

<BlogPostLayout
  lang="vi"
  post={post}
  canonicalPath={canonicalPath}
  alternates={alternates}
  relatedPosts={relatedPosts}
  seriesPosts={seriesPosts}
  prevPost={prevPost}
  nextPost={nextPost}
>
  <Content />
</BlogPostLayout>
