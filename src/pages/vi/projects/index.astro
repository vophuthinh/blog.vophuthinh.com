---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/project/ProjectCard.astro';
import { t } from '../../../utils/i18n';
import { getProjectsByLang } from '../../../utils/projects';

const lang = 'vi' as const;
const i18n = t(lang);
const projects = await getProjectsByLang(lang);
---

<BaseLayout
  lang={lang}
  title={`${i18n.pages.projectsTitle} | Võ Phú Thịnh`}
  description={i18n.pages.projectsDescription}
  canonicalPath="/vi/projects"
>
  <main id="main-content" class="container-shell py-16 flex flex-col gap-10">
    <!-- Header -->
    <header class="border-b border-[var(--border-color)] pb-6">
      <h1 class="text-[48px] font-bold leading-[1.1] tracking-[-0.02em] mb-2">{i18n.pages.projectsTitle}</h1>
      <p class="text-lg leading-relaxed text-[var(--text-secondary)] max-w-[800px]">{i18n.pages.projectsDescription}</p>
    </header>

    <!-- Project Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => <ProjectCard project={project} lang={lang} />)}
    </div>

    {projects.length === 0 && <p class="text-[var(--text-muted)]">{i18n.common.noProjects}</p>}
  </main>
</BaseLayout>
