---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts';
import { t } from '../../utils/i18n';

const lang = 'vi' as const;
const i18n = t(lang);
---

<BaseLayout
  lang={lang}
  title={`${i18n.pages.contactTitle} | Võ Phú Thịnh`}
  description={i18n.pages.contactDescription}
  canonicalPath="/vi/contact"
>
  <main id="main-content" class="container-shell py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Cột trái: Thông tin liên hệ -->
      <div class="md:col-span-5 flex flex-col gap-10">
        <div>
          <h1 class="font-bold leading-[1.1] tracking-[-0.02em] mb-4" style="font-size: clamp(2rem, 5vw, 3rem)">Liên hệ</h1>
          <p class="text-lg leading-relaxed text-[var(--text-secondary)]">
            Bạn muốn hợp tác về hệ thống doanh nghiệp, tích hợp AI, hoặc tự động hóa hiệu suất cao? Hãy cùng xây dựng thứ gì đó thật chất lượng.
          </p>
        </div>

        <!-- Contact Links -->
        <div class="flex flex-col gap-4">
          <!-- Email Card -->
          <div class="bg-[var(--bg-card)] border border-[var(--border-color)] p-6 rounded-lg flex items-center justify-between group hover:border-[var(--brand-light)] transition-colors">
            <div class="flex items-center gap-4">
              <div class="bg-[var(--bg-surface)] p-2 rounded-lg flex items-center justify-center text-[var(--brand)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <div class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wider">Email trực tiếp</div>
                <div class="font-mono text-[var(--text-primary)]">vophuthinhcm@gmail.com</div>
              </div>
            </div>
          </div>

          <!-- Social Links Grid -->
          <div class="grid grid-cols-2 gap-4">
            <a href={SITE.github} target="_blank" rel="noreferrer" class="bg-[var(--bg-card)] border border-[var(--border-color)] p-4 rounded-lg flex flex-col items-start gap-4 group hover:border-[var(--brand-light)] transition-colors">
              <div class="bg-[var(--bg-surface)] p-2 rounded-lg text-[var(--text-muted)] group-hover:text-[var(--brand)] transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
              </div>
              <div class="text-sm font-medium text-[var(--text-primary)]">GitHub</div>
            </a>
            <a href={SITE.linkedin} target="_blank" rel="noreferrer" class="bg-[var(--bg-card)] border border-[var(--border-color)] p-4 rounded-lg flex flex-col items-start gap-4 group hover:border-[var(--brand-light)] transition-colors">
              <div class="bg-[var(--bg-surface)] p-2 rounded-lg text-[var(--text-muted)] group-hover:text-[var(--brand)] transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
              </div>
              <div class="text-sm font-medium text-[var(--text-primary)]">LinkedIn</div>
            </a>
          </div>
        </div>
      </div>

      <!-- Cột phải: Form liên hệ -->
      <div class="md:col-span-7 bg-[var(--bg-card)] border border-[var(--border-color)] rounded-lg p-10">
        <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
          <span class="text-[var(--brand)]">›_</span>
          <span>System.init_contact()</span>
        </h2>

        <form class="flex flex-col gap-6" id="contact-form">
          <!-- Honeypot anti-spam -->
          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_ts" id="form-ts" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wider" for="name">Họ tên</label>
              <input
                class="bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-primary)] rounded-lg px-4 py-2 font-mono text-base focus:border-[var(--brand-light)] focus:ring-1 focus:ring-[var(--brand-light)] focus:outline-none transition-colors placeholder:text-[var(--text-muted)]"
                id="name" name="name" placeholder="Nguyễn Văn A" type="text" required
              />
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wider" for="email">Email</label>
              <input
                class="bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-primary)] rounded-lg px-4 py-2 font-mono text-base focus:border-[var(--brand-light)] focus:ring-1 focus:ring-[var(--brand-light)] focus:outline-none transition-colors placeholder:text-[var(--text-muted)]"
                id="email" name="email" placeholder="email@example.com" type="email" required
              />
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wider" for="subject">Chủ đề</label>
            <input
              class="bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-primary)] rounded-lg px-4 py-2 font-mono text-base focus:border-[var(--brand-light)] focus:ring-1 focus:ring-[var(--brand-light)] focus:outline-none transition-colors placeholder:text-[var(--text-muted)]"
              id="subject" name="subject" placeholder="Trao đổi về dự án" type="text" required
            />
          </div>
          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-[var(--text-muted)] uppercase tracking-wider" for="message">Nội dung</label>
            <textarea
              class="bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-primary)] rounded-lg px-4 py-2 font-mono text-base focus:border-[var(--brand-light)] focus:ring-1 focus:ring-[var(--brand-light)] focus:outline-none transition-colors placeholder:text-[var(--text-muted)] resize-none"
              id="message" name="message" placeholder="Mô tả yêu cầu kỹ thuật của bạn..." rows="5" required
            ></textarea>
          </div>

          <!-- Status messages -->
          <div id="form-success" class="hidden rounded-lg border border-green-500/30 bg-green-500/10 p-4 text-sm text-green-400">
            ✓ Tin nhắn đã được gửi thành công! Mình sẽ phản hồi sớm nhất.
          </div>
          <div id="form-error" class="hidden rounded-lg border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-400">
            ✗ Gửi thất bại. Vui lòng thử lại hoặc liên hệ qua email trực tiếp.
          </div>

          <div class="pt-2 flex justify-end">
            <button
              type="submit"
              id="submit-btn"
              class="bg-[var(--brand)] text-white text-sm font-medium px-10 py-3 rounded-md flex items-center gap-2 hover:brightness-105 transition-colors"
            >
              Gửi tin nhắn →
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script is:inline>
    (() => {
      const SERVICE_ID = 'service_48b0gyq';
      const TEMPLATE_ID = 'template_4d2wwti';
      const PUBLIC_KEY = 'oF2S6I0ORnNleh8lm';

      const form = document.getElementById('contact-form');
      const btn = document.getElementById('submit-btn');
      const successEl = document.getElementById('form-success');
      const errorEl = document.getElementById('form-error');
      const tsInput = document.getElementById('form-ts');

      if (tsInput) tsInput.value = String(Date.now());

      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        successEl.classList.add('hidden');
        errorEl.classList.add('hidden');

        // Honeypot check
        if (form.website && form.website.value) return;

        // Timestamp anti-spam (min 3s)
        const ts = Number(tsInput?.value || 0);
        if (Date.now() - ts < 3000) {
          errorEl.classList.remove('hidden');
          return;
        }

        const name = form.name.value.trim();
        const email = form.email.value.trim();
        const subject = form.subject.value.trim();
        const message = form.message.value.trim();

        if (!name || !email || !message) return;

        btn.disabled = true;
        btn.textContent = 'Đang gửi...';

        try {
          await emailjs.send(SERVICE_ID, TEMPLATE_ID, {
            from_name: name,
            email_id: email,
            message: subject ? `[${subject}] ${message}` : message,
          }, PUBLIC_KEY);

          form.reset();
          if (tsInput) tsInput.value = String(Date.now());
          successEl.classList.remove('hidden');
        } catch (err) {
          console.error('EmailJS error:', err);
          errorEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Gửi tin nhắn →';
        }
      });
    })();
  </script>
</BaseLayout>
