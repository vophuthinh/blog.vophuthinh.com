---
const target = '/vi';
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={`https://blog.vophuthinh.com${target}`} />
    <title>Redirecting...</title>
    <script is:inline>
      window.location.replace('/vi');
    </script>
  </head>
  <body>
    <a href={target}>Redirecting to {target}</a>
  </body>
</html>
