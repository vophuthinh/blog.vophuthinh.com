---
import type { Locale } from '../consts';
import Seo from '../components/seo/Seo.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import SearchModal from '../components/common/SearchModal.astro';
import BackToTop from '../components/common/BackToTop.astro';
import type { AlternateLink } from '../utils/seo';
import '../styles/global.css';

interface Props {
  lang: Locale;
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  type?: 'website' | 'article';
  alternates?: AlternateLink[];
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  canonicalPath,
  ogImage,
  type = 'website',
  alternates,
  publishedTime,
  modifiedTime,
  noindex = false
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/assets/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-icon-180x180.png" />
    <link rel="manifest" href="/assets/favicon/manifest.json" />
    <meta name="theme-color" content="#050505" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f0f2f5" media="(prefers-color-scheme: light)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" /></noscript>
    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      type={type}
      alternates={alternates}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
    />
    <slot name="head" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded focus:bg-[var(--brand)] focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white">Skip to content</a>
    <Header lang={lang} pathname={pathname} />
    <slot />
    <Footer lang={lang} />
    <SearchModal lang={lang} />
    <BackToTop />
  </body>
</html>
